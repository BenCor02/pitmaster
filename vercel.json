{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/((?!api|assets|favicon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/sitemap",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ]
}
